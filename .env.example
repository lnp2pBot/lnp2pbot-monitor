# lnp2pBot Health Monitor Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Telegram bot token for sending alerts
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated list of Telegram chat IDs where alerts will be sent
# For private chats: Use your user ID (e.g., 123456789)
# For groups: Use negative group ID (e.g., -1001234567890)
# Get your chat ID from @userinfobot on Telegram
ADMIN_CHAT_ID=-1001234567890,477262720

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Server port (default: 3000)
PORT=3000

# Authentication token for heartbeat endpoint (recommended)
# The bot must include this in the Authorization header
# Generate a strong random token
AUTH_TOKEN=super-secret-token-change-this-immediately

# Node.js environment (development, production)
NODE_ENV=production

# =============================================================================
# MONITORING THRESHOLDS
# =============================================================================

# Minutes before considering heartbeat as missing (default: 6)
# Should be 3x the bot's heartbeat interval
MISSING_HEARTBEAT_THRESHOLD=6

# Minutes between critical alerts (default: 5)
# Prevents spam for critical issues
CRITICAL_ALERT_THROTTLE=5

# Minutes between warning alerts (default: 30)
# Prevents spam for warning issues
WARNING_ALERT_THROTTLE=30

# =============================================================================
# MEMORY THRESHOLDS
# =============================================================================

# Memory usage threshold for warnings in MB (default: 1024)
HIGH_MEMORY_THRESHOLD=1024

# Memory usage threshold for critical alerts in MB (default: 2048)
VERY_HIGH_MEMORY_THRESHOLD=2048

# =============================================================================
# OTHER THRESHOLDS
# =============================================================================

# Days of uptime before suggesting restart (default: 30)
LONG_UPTIME_THRESHOLD=30

# =============================================================================
# LOGGING
# =============================================================================

# Logging level: error, warn, info, debug (default: info)
# Use 'debug' for troubleshooting, 'error' for production
LOG_LEVEL=info

# =============================================================================
# EXAMPLES
# =============================================================================

# Example 1: Basic configuration for development
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# ADMIN_CHAT_ID=123456789,987654321
# AUTH_TOKEN=my-secret-dev-token
# LOG_LEVEL=debug

# Example 2: Production configuration with tighter monitoring
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# ADMIN_CHAT_ID=-1001234567890,477262720
# AUTH_TOKEN=very-long-secure-token-for-production-use
# MISSING_HEARTBEAT_THRESHOLD=4
# CRITICAL_ALERT_THROTTLE=3
# HIGH_MEMORY_THRESHOLD=512
# LOG_LEVEL=warn

# Example 3: Relaxed configuration for testing
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# ADMIN_CHAT_ID=123456789,987654321
# MISSING_HEARTBEAT_THRESHOLD=10
# WARNING_ALERT_THROTTLE=60
# LOG_LEVEL=info